{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://normattiva-rag.local/schemas/fip_ind_documentary_support_request_schema_v1.json",
  "title": "FIP-IND Documentary Support Request v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "case_id",
    "trace_id",
    "api_version",
    "caller_module",
    "target_module",
    "timestamp",
    "payload"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "api_version": {
      "type": "string",
      "const": "2.0"
    },
    "caller_module": {
      "type": "string",
      "minLength": 1
    },
    "target_module": {
      "type": "string",
      "const": "B17_FIPINDSupportLayer"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "act_title",
        "question_ids",
        "query_text",
        "documentary_scope",
        "requested_outputs"
      ],
      "properties": {
        "act_title": {
          "type": "string",
          "minLength": 1
        },
        "question_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "Q01",
              "Q02",
              "Q03",
              "Q04",
              "Q05",
              "Q06",
              "Q07",
              "Q08",
              "Q09",
              "Q10"
            ]
          },
          "uniqueItems": true
        },
        "query_text": {
          "type": "string",
          "minLength": 1
        },
        "documentary_scope": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_priority",
            "require_official_uri",
            "require_vigenza_check",
            "require_crossref_check",
            "require_coverage_check"
          ],
          "properties": {
            "source_priority": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            },
            "require_official_uri": {
              "type": "boolean"
            },
            "require_vigenza_check": {
              "type": "boolean"
            },
            "require_crossref_check": {
              "type": "boolean"
            },
            "require_coverage_check": {
              "type": "boolean"
            }
          }
        },
        "requested_outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "documentary_packet",
              "citation_packets",
              "vigenza_status",
              "crossref_status",
              "coverage_status",
              "fip_ind_evidence_pack",
              "warnings",
              "errors",
              "blocks",
              "technical_trace"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}