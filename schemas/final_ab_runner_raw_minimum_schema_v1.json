  "crossref_unresolved_values": [
    "UNRESOLVED",
    "IRRESOLTO",
    "PENDING",
    "NOT_FOUND"
  ],
  "coverage_block_values": [
    "INADEQUATE",
    "INSUFFICIENT",
    "CRITICAL_GAP",
    "GAP_ESSENTIAL"
  ]
}
