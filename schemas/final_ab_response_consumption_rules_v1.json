      ],
      "forbidden_level_a_targets": [
        "A4_M07Governor",
        "A6_RACBuilder",
        "A5_FinalComplianceGate",
        "A7_OutputAuthorizer"
      ],
      "requires_human_review": true,
      "requires_quarantine": false,
      "blocks_opponibility": true,
      "notes": "Degraded responses require methodological review and cannot feed sensitive modules."
    },
    {
