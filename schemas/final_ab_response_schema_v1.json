{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinalABResponse",
  "type": "object",
  "required": [
    "request_id",
    "case_id",
    "trace_id",
    "api_version",
    "responder_module",
    "status",
    "payload",
    "warnings",
    "errors",
    "blocks",
    "timestamp"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "api_version": {
      "type": "string",
      "minLength": 1
    },
    "responder_module": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "SUCCESS_WITH_WARNINGS",
        "DEGRADED",
        "BLOCKED",
        "REJECTED",
        "ERROR"
      ]
    },
    "payload": {
      "type": "object"
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}